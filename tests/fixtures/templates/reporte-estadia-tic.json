{
  "type": "reporte-estadia-tic",
  "title": "Reporte de Estadía TIC",
  "project_defaults": {
    "language": "es-MX",
    "voice": "third_person_singular",
    "document_type": "reporte_estadia_tic",
    "scope_policy": ""
  },
  "paths": {
    "manual_dir": "{tesina_root}/guides/manual-estadia-tic",
    "manual_pdf": "{tesina_root}/guides/GUÍA DE REFERENCIA PARA LA ELABORACIÓN DEL REPORTE DE ESTADÍA TIC (2).pdf",
    "extracted_dir": "{tesina_root}/extracted",
    "extracted_dir_policy": "rules_traceability_only",
    "example_pdf": "{tesina_root}/example_tesina/RE-Ejemplo.pdf"
  },
  "normative": {
    "excluded_front_matter": {
      "carta responsiva": "La carta responsiva está excluida del arnés.",
      "carta de liberación": "Las cartas de liberación están excluidas del arnés.",
      "carta de liberacion": "Las cartas de liberación están excluidas del arnés.",
      "hoja de guarda": "La hoja de guarda está excluida del arnés."
    },
    "first_person_patterns": [
      "\\byo\\b", "\\bnosotros\\b", "\\bnosotras\\b", "\\bmi\\b", "\\bmis\\b",
      "\\bnuestro\\b", "\\bnuestra\\b", "\\bdesarrollé\\b", "\\bdesarrollamos\\b",
      "\\bconsidero\\b", "\\bcreemos\\b"
    ],
    "subjective_terms": [
      "excelente", "impresionante", "increíble", "increible", "claramente",
      "obviamente", "afortunadamente", "lamentablemente", "simplemente",
      "éxito", "exito", "fracaso"
    ]
  },
  "advisor_overrides": [
    {
      "id": "margins-2-5cm-non-cover",
      "source": "asesor académico",
      "rule": "Aplicar márgenes de 2.5 cm en todo el documento excepto la portada.",
      "applies_to": "all_non_cover_sections",
      "status": "active"
    }
  ],
  "preliminaries": {
    "cover": { "enabled": true, "numbering": "none" },
    "blank_page": { "enabled": true, "title": "HOJA EN BLANCO", "numbering": "roman", "start": 2 },
    "responsibility_page": {
      "enabled": true,
      "numbering": "roman",
      "text": "Aunque este trabajo hubiere servido para obtener el Grado de Técnico Superior Universitario en Desarrollo de Software Multiplataforma y hubiere sido aprobado por la Dirección de Tecnologías de la Información y Comunicación, sólo su autor es responsable de las doctrinas en él emitida"
    },
    "roman_pagination": {
      "enabled": true, "starts_after_cover": true, "format": "lowerRoman",
      "position": "bottom_right", "font": "Times New Roman", "font_pt": 12
    },
    "body_pagination_start": {
      "section_id": "introduccion", "start": 1, "format": "decimal",
      "position": "bottom_right", "font": "Times New Roman", "font_pt": 12
    }
  },
  "structure": [
    { "type": "cover_from_asset", "asset": "cover" },
    { "type": "blank_page" },
    { "type": "fixed_text_page", "text": "Aunque este trabajo hubiere servido para obtener el Grado de Técnico Superior Universitario en Desarrollo de Software Multiplataforma y hubiere sido aprobado por la Dirección de Tecnologías de la Información y Comunicación, sólo su autor es responsable de las doctrinas en él emitida" },
    {
      "type": "sections",
      "preliminary_pagination": { "format": "lowerRoman", "start": 2 },
      "body_restart_section": "introduccion",
      "body_pagination": { "format": "decimal", "start": 1 }
    }
  ],
  "format": {
    "page_size": "letter",
    "page_margins_cm": {
      "cover_policy": "preserve_template",
      "non_cover": { "top": 2.5, "right": 2.5, "bottom": 2.5, "left": 2.5 },
      "source": "advisor_override:margins-2-5cm-non-cover"
    },
    "body_font": "Times New Roman",
    "body_font_pt": 12,
    "line_spacing": 1.5,
    "first_line_indent_cm": 1.25,
    "paragraph_space_after_pt": 18,
    "page_numbers_start_at": "introduccion",
    "page_number_position": "bottom_right",
    "table_policy": "horizontal_lines_only_no_color",
    "figure_caption_position": "below",
    "reference_hanging_indent_cm": 1.27,
    "keyword_bold_terms": {}
  },
  "apa7": {
    "enabled": true,
    "style": "APA 7",
    "in_text_citation": "author_date",
    "requires_reference_for_each_citation": true,
    "requires_citation_for_each_reference": true,
    "reference_order": "alphabetical",
    "reference_hanging_indent_cm": 1.27,
    "direct_quote_requires_locator": true,
    "allowed_reference_heading": "REFERENCIAS BIBLIOGRÁFICAS"
  },
  "privacy": {
    "forbidden_in_body_patterns": [
      "\\b[A-Z&Ñ]{3,4}\\d{6}[A-Z0-9]{3}\\b",
      "\\b\\d{10}\\b",
      "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}"
    ],
    "sensitive_context_fields": ["RFC", "Teléfono", "Correo Electrónico", "Domicilio"],
    "policy": "Los datos sensibles pueden permanecer en el contexto interno, pero no deben entrar al cuerpo salvo instrucción explícita."
  },
  "strict_policy": {
    "draft": { "allow_pending": true, "length_violations": "warning", "missing_evidence": "warning", "apa_violations": "warning" },
    "strict": { "allow_pending": false, "length_violations": "error", "missing_evidence": "error", "apa_violations": "error" }
  },
  "cross_consistency": {
    "enabled": true,
    "contested_stack_terms": []
  },
  "documents_tools": {
    "enabled": true,
    "required_in_strict": true,
    "scripts": ["insert_toc.py", "heading_audit.py", "section_audit.py", "style_lint.py", "captions_and_crossrefs.py", "table_geometry.py", "privacy_scrub.py"],
    "render_docx": "{documents_render_docx}"
  },
  "ledger_seed": [
    { "classification": "confirmado", "claim": "La portada se toma desde la plantilla DOCX existente." },
    { "classification": "pendiente", "claim": "PENDIENTE: fuentes bibliográficas realmente consultadas para el marco teórico." }
  ],
  "context_schema": {
    "topics": [
      {
        "id": "alumno",
        "title": "Datos del Alumno",
        "required": true,
        "consumed_by": ["agradecimientos", "introduccion"],
        "fields": [
          { "key": "nombre", "label": "Nombre del Alumno", "required": true },
          { "key": "carrera", "label": "Carrera", "required": true },
          { "key": "grado_grupo", "label": "Grado y Grupo", "required": false },
          { "key": "asesor", "label": "Nombre del Asesor Académico", "required": true },
          { "key": "segundo_revisor", "label": "Nombre del Segundo Revisor", "required": false }
        ]
      },
      {
        "id": "organizacion",
        "title": "Datos de la Organización",
        "required": true,
        "consumed_by": ["agradecimientos", "introduccion", "capitulo-i-marco-contextual"],
        "fields": [
          { "key": "nombre", "label": "Nombre", "required": true },
          { "key": "alias", "label": "Alias (nombre corto)", "required": false },
          { "key": "tipo", "label": "Tipo", "required": false },
          { "key": "rfc", "label": "RFC", "required": false, "sensitive": true },
          { "key": "telefono", "label": "Teléfono", "required": false, "sensitive": true },
          { "key": "direccion", "label": "Dirección Empresa", "required": false, "sensitive": true },
          { "key": "localidad", "label": "Localidad", "required": false },
          { "key": "municipio", "label": "Municipio", "required": false },
          { "key": "estado", "label": "Estado", "required": false }
        ]
      },
      {
        "id": "tutor",
        "title": "Datos del Tutor Empresarial",
        "required": false,
        "consumed_by": ["agradecimientos"],
        "fields": [
          { "key": "nombre", "label": "Nombre", "required": false },
          { "key": "apellido_paterno", "label": "Apellido Paterno", "required": false },
          { "key": "apellido_materno", "label": "Apellido Materno", "required": false }
        ]
      },
      {
        "id": "estadia",
        "title": "Datos de la Estadía",
        "required": true,
        "consumed_by": ["introduccion", "resumen"],
        "fields": [
          { "key": "periodo_inicio", "label": "Inicio de estadía", "required": true },
          { "key": "periodo_fin", "label": "Fin de estadía", "required": true },
          { "key": "duracion_horas", "label": "Duración en horas", "required": true }
        ]
      },
      {
        "id": "proyecto",
        "title": "Datos del Proyecto",
        "required": true,
        "multiline": true,
        "consumed_by": ["resumen", "introduccion", "capitulo-i-marco-contextual"],
        "prompt": "Describe el proyecto: nombre registrado, objetivo general, objetivos específicos, alcance, problemática y justificación."
      },
      {
        "id": "sustento_tecnico",
        "title": "Sustento técnico",
        "required": false,
        "multiline": true,
        "consumed_by": ["introduccion", "capitulo-iii-metodologia"],
        "prompt": "Tecnologías y arquitectura realmente usadas (lenguaje, framework, patrón, librerías)."
      }
    ]
  },
  "sections": [
    { "id": "agradecimientos", "title": "AGRADECIMIENTOS", "optional": true, "order": 10 },
    { "id": "indice", "title": "ÍNDICE", "required": true, "order": 20 },
    { "id": "resumen", "title": "RESUMEN", "required": true, "order": 30 },
    { "id": "introduccion", "title": "INTRODUCCIÓN", "required": true, "order": 40 },
    { "id": "capitulo-i-marco-contextual", "title": "CAPÍTULO I. MARCO CONTEXTUAL", "required": true, "order": 50 },
    { "id": "capitulo-ii-marco-teorico", "title": "CAPÍTULO II. MARCO TEÓRICO", "required": true, "order": 60 },
    { "id": "capitulo-iii-metodologia", "title": "CAPÍTULO III. METODOLOGÍA O PROPUESTA A IMPLEMENTAR", "required": true, "order": 70 },
    { "id": "capitulo-iv-resultados", "title": "CAPÍTULO IV. RESULTADOS Y EXPERIENCIAS", "required": true, "order": 80 },
    { "id": "conclusiones", "title": "CONCLUSIONES", "required": true, "order": 90 },
    { "id": "anexos", "title": "ANEXOS", "required": true, "order": 100 },
    { "id": "referencias", "title": "REFERENCIAS BIBLIOGRÁFICAS", "required": true, "order": 110 }
  ],
  "section_contracts": {
    "agradecimientos": {
      "title": "AGRADECIMIENTOS",
      "length": { "target_pages": 1, "min_words": 180, "max_words": 500 },
      "required_content": ["agradecimiento institucional", "asesor académico", "tutora empresarial", "organización receptora"],
      "evidence_required": false, "apa_required": false, "pending_allowed_in_draft": false
    },
    "indice": {
      "title": "ÍNDICE",
      "toc": true,
      "length": { "target_pages": 1 },
      "required_content": ["campo TOC dinámico", "títulos hasta tercer nivel", "paginación"],
      "detect": { "campo TOC dinámico": ["[[toc]]", "toc"], "títulos hasta tercer nivel": ["[[toc]]", "índice"], "paginación": ["[[toc]]", "paginación", "página"] },
      "evidence_required": false, "apa_required": false, "pending_allowed_in_draft": false
    },
    "resumen": {
      "title": "RESUMEN",
      "length": { "target_pages": 1, "min_words": 220, "max_words": 520 },
      "required_content": ["tema del proyecto", "enfoque del trabajo", "motivo del proyecto", "resultados importantes o PENDIENTE"],
      "detect": { "resultados importantes o PENDIENTE": ["resultado", "pendiente"] },
      "evidence_required": true, "apa_required": false, "pending_allowed_in_draft": true
    },
    "introduccion": {
      "title": "INTRODUCCIÓN",
      "length": { "min_pages": 2, "max_pages": 4, "min_words": 900, "max_words": 1800 },
      "required_content": ["objetivo", "justificación", "problema", "delimitación espacial", "delimitación temporal", "unidad de análisis", "sustento técnico", "método o procedimiento", "capitulado"],
      "evidence_required": true, "apa_required": false, "pending_allowed_in_draft": true
    },
    "capitulo-i-marco-contextual": {
      "title": "CAPÍTULO I. MARCO CONTEXTUAL",
      "required_content": ["situación de la empresa", "historia", "ubicación", "área asignada", "actores", "planteamiento del problema", "causas", "evidencias", "justificación", "objetivo general", "objetivos específicos"],
      "evidence_required": true, "apa_required": false, "pending_allowed_in_draft": true
    },
    "capitulo-ii-marco-teorico": {
      "title": "CAPÍTULO II. MARCO TEÓRICO",
      "required_content": ["fundamentación teórica", "enfoque deductivo", "autores", "teorías", "conceptos clave", "antecedentes"],
      "evidence_required": true, "apa_required": true, "pending_allowed_in_draft": true
    },
    "capitulo-iii-metodologia": {
      "title": "CAPÍTULO III. METODOLOGÍA O PROPUESTA A IMPLEMENTAR",
      "required_content": ["estrategia", "técnica o procedimiento", "procesos", "instrumentos", "diseño", "aplicación de teoría"],
      "evidence_required": true, "apa_required": true, "pending_allowed_in_draft": true
    },
    "capitulo-iv-resultados": {
      "title": "CAPÍTULO IV. RESULTADOS Y EXPERIENCIAS",
      "required_content": ["evaluación", "alcance", "resultados por objetivo", "evidencias", "experiencias", "aportación"],
      "evidence_required": true, "apa_required": false, "pending_allowed_in_draft": true
    },
    "conclusiones": {
      "title": "CONCLUSIONES",
      "required_content": ["síntesis", "relación con objetivos", "hallazgos", "aportaciones", "líneas futuras"],
      "evidence_required": true, "apa_required": false, "pending_allowed_in_draft": true
    },
    "anexos": {
      "title": "ANEXOS",
      "required_content": ["material de apoyo", "referencias desde el cuerpo", "separadores por anexo"],
      "evidence_required": false, "apa_required": false, "pending_allowed_in_draft": true
    },
    "referencias": {
      "title": "REFERENCIAS BIBLIOGRÁFICAS",
      "references_list": true,
      "required_content": ["fuentes citadas", "formato APA 7", "orden alfabético"],
      "detect": { "fuentes citadas": ["referencias", "pendiente"], "formato APA 7": ["apa 7", "apa"], "orden alfabético": ["alfabético", "orden"] },
      "evidence_required": false, "apa_required": true, "pending_allowed_in_draft": true
    }
  }
}
